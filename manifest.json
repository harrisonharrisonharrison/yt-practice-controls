{
  "manifest_version": 3,
  "name": "YTPracticeControls",
  "version": "1.0",
  "description": "YouTube video looper and speed controller",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/watch*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}